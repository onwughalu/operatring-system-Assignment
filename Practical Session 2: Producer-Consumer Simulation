#include <stdio.h>
#include <stdlib.h>
#include <pthread.h>
#include <semaphore.h>
#include <unistd.h>

#define BUFFER_SIZE 5
#define TOTAL_ITEMS 15

int buffer[BUFFER_SIZE];
int in = 0;
int out = 0;

sem_t mutex;
sem_t empty;
sem_t full;

void* producer(void* arg) {
    for (int i = 0; i < TOTAL_ITEMS; i++) {
        int item = rand() % 100; // Generate a random item

        sem_wait(&empty); // Decrement empty slots (block if buffer is full)
        sem_wait(&mutex); // Enter critical section

        // Add item to circular buffer
        buffer[in] = item;
        printf("Producer produced: %d at index %d\n", item, in);
        in = (in + 1) % BUFFER_SIZE;

        sem_post(&mutex); // Leave critical section
        sem_post(&full);  // Increment filled slots (signal consumer)

        // Sleep to simulate varying production speeds
        usleep((rand() % 150) * 1000); 
    }
    return NULL;
}

void* consumer(void* arg) {
    for (int i = 0; i < TOTAL_ITEMS; i++) {
        sem_wait(&full);  // Decrement filled slots (block if buffer is empty)
        sem_wait(&mutex); // Enter critical section

        // Remove item from circular buffer
        int item = buffer[out];
        printf("Consumer consumed: %d from index %d\n", item, out);
        out = (out + 1) % BUFFER_SIZE;

        sem_post(&mutex); // Leave critical section
        sem_post(&empty); // Increment empty slots (signal producer)

        // Sleep to simulate varying consumption speeds
        usleep((rand() % 300) * 1000); 
    }
    return NULL;
}

int main() {
    pthread_t prod_tid, cons_tid;
    srand(time(NULL));

    // Initialize semaphores
    sem_init(&mutex, 0, 1);           // Binary semaphore for mutual exclusion
    sem_init(&empty, 0, BUFFER_SIZE);  // Counting semaphore for empty slots
    sem_init(&full, 0, 0);            // Counting semaphore for filled slots

    pthread_create(&prod_tid, NULL, producer, NULL);
    pthread_create(&cons_tid, NULL, consumer, NULL);

    pthread_join(prod_tid, NULL);
    pthread_join(cons_tid, NULL);

    // Clean up
    sem_destroy(&mutex);
    sem_destroy(&empty);
    sem_destroy(&full);

    printf("Simulation completed.\n");
    return 0;
}
