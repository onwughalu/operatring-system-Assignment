
#include <stdio.h>
#include <stdlib.h>
#include <pthread.h>

#define NUM_THREADS 10
#define INCREMENTS_PER_THREAD 100000

long long shared_counter = 0;
pthread_mutex_t lock;

// Thread function without synchronization
void* increment_without_mutex(void* arg) {
    for (int i = 0; i < INCREMENTS_PER_THREAD; i++) {
        shared_counter++; // Race condition occurs here
    }
    return NULL;
}

// Thread function with synchronization
void* increment_with_mutex(void* arg) {
    for (int i = 0; i < INCREMENTS_PER_THREAD; i++) {
        pthread_mutex_lock(&lock);
        shared_counter++; // Protected critical section
        pthread_mutex_unlock(&lock);
    }
    return NULL;
}

int main() {
    pthread_t threads[NUM_THREADS];
    long long expected_value = (long long)NUM_THREADS * INCREMENTS_PER_THREAD;

    printf("Expected Final Counter Value: %lld\n\n", expected_value);

    // --- TEST 1: WITHOUT MUTEX ---
    shared_counter = 0;
    printf("Running Test 1: Without Mutex...\n");
    for (int i = 0; i < NUM_THREADS; i++) {
        pthread_create(&threads[i], NULL, increment_without_mutex, NULL);
    }
    for (int i = 0; i < NUM_THREADS; i++) {
        pthread_join(threads[i], NULL);
    }
    printf("Result WITHOUT Mutex: %lld\n", shared_counter);
    if (shared_counter != expected_value) {
        printf("Observation: Data loss detected due to race conditions.\n\n");
    } else {
        printf("Observation: No data loss detected (unlikely for high iteration counts).\n\n");
    }

    // --- TEST 2: WITH MUTEX ---
    shared_counter = 0;
    pthread_mutex_init(&lock, NULL);
    
    printf("Running Test 2: With Mutex...\n");
    for (int i = 0; i < NUM_THREADS; i++) {
        pthread_create(&threads[i], NULL, increment_with_mutex, NULL);
    }
    for (int i = 0; i < NUM_THREADS; i++) {
        pthread_join(threads[i], NULL);
    }
    printf("Result WITH Mutex: %lld\n", shared_counter);
    
    pthread_mutex_destroy(&lock);
    return 0;
}
