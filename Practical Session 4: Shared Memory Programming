#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>
#include <sys/ipc.h>
#include <sys/shm.h>
#include <sys/types.h>
#include <sys/wait.h>
#include <semaphore.h>
#include <string.h>

#define SHM_KEY 0x1234
#define MSG_SIZE 256

// Struct defining the layout of the shared memory segment
struct SharedMemory {
    sem_t sem_write_done; // Semaphore to signal that parent has written
    char message[MSG_SIZE];
};

int main() {
    int shmid;
    struct SharedMemory *shm_ptr;

    // Create the shared memory segment
    shmid = shmget(SHM_KEY, sizeof(struct SharedMemory), IPC_CREAT | 0666);
    if (shmid < 0) {
        perror("shmget failed");
        exit(1);
    }

    // Attach to the shared memory segment
    shm_ptr = (struct SharedMemory *)shmat(shmid, NULL, 0);
    if (shm_ptr == (void *)-1) {
        perror("shmat failed");
        exit(1);
    }

    // Initialize the shared semaphore
    // Second parameter (pshared) = 1 means shared across processes
    // Third parameter (value) = 0 means start locked
    if (sem_init(&shm_ptr->sem_write_done, 1, 0) < 0) {
        perror("sem_init failed");
        exit(1);
    }

    pid_t pid = fork();

    if (pid < 0) {
        perror("fork failed");
        exit(1);
    } 
    else if (pid == 0) {
        // --- CHILD PROCESS (Reader) ---
        // Child attaches to the same memory space automatically on fork
        printf("[Child]: Waiting for parent to write data...\n");
        
        sem_wait(&shm_ptr->sem_write_done); // Blocks until parent posts
        
        printf("[Child]: Read message from shared memory: \"%s\"\n", shm_ptr->message);
        
        // Detach from shared memory
        shmdt(shm_ptr);
        printf("[Child]: Detached and exiting.\n");
        exit(0);
    } 
    else {
        // --- PARENT PROCESS (Writer) ---
        sleep(2); // Sleep to demonstrate that the child waits successfully
        
        printf("[Parent]: Writing message to shared memory...\n");
        strncpy(shm_ptr->message, "Hello from the Parent process!", MSG_SIZE);
        
        printf("[Parent]: Signaling child...\n");
        sem_post(&shm_ptr->sem_write_done); // Wake up child
        
        // Wait for child to exit
        wait(NULL);

        // Cleanup
        sem_destroy(&shm_ptr->sem_write_done);
        shmdt(shm_ptr); // Detach
        shmctl(shmid, IPC_RMID, NULL); // Destroy shared memory segment
        printf("[Parent]: Shared memory cleaned up. Exiting.\n");
    }

    return 0;
}
